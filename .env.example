# Required for article comparison
OPENAI_API_KEY=sk-...

# Required for transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=
#
# Production (e.g. Railway): long video + AssemblyAI can take several minutes.
# If you see 502 "Application failed to respond", raise the service HTTP request
# timeout (e.g. 300–900s) and give the instance enough RAM for large uploads.

# Optional: speaker diarization (Speaker A, B, …)
# ASSEMBLYAI_SPEAKER_LABELS=false
# ASSEMBLYAI_SPEAKERS_EXPECTED=2
# ASSEMBLYAI_SPEAKER_A_NAME=Will
# ASSEMBLYAI_SPEAKER_B_NAME=Aron

OPENAI_COMPARE_MODEL=gpt-4o-mini
