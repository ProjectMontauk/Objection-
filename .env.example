# Required for article comparison
OPENAI_API_KEY=sk-...

# Demo build: skip real transcription; serve fixed Enhanced Games interview text
# NEXT_PUBLIC_DEMO_MODE=1
# Optional override for the embedded player (place file under public/ or use CDN URL)
# NEXT_PUBLIC_DEMO_VIDEO_SRC=/demo-interview.mp4

# Transcription when demo mode is off (AssemblyAI)
ASSEMBLYAI_API_KEY=

# Optional: speaker diarization (Speaker A, B, …)
# ASSEMBLYAI_SPEAKER_LABELS=false
# ASSEMBLYAI_SPEAKERS_EXPECTED=2
# ASSEMBLYAI_SPEAKER_A_NAME=Will
# ASSEMBLYAI_SPEAKER_B_NAME=Aron

OPENAI_COMPARE_MODEL=gpt-4o-mini
