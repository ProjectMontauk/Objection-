# Required for article comparison
OPENAI_API_KEY=sk-...

# Required for transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=

# Optional: speaker diarization (Speaker A, B, …). Set to 0 or false to disable.
# ASSEMBLYAI_SPEAKER_LABELS=false
# Hint number of speakers (1–20); omit if unsure (recommended for interviews: 2).
# ASSEMBLYAI_SPEAKERS_EXPECTED=2

# Map diarization letters to names (defaults: A = Will interviewer, B = Aron interviewee).
# If names are reversed in the transcript, swap these two lines.
# ASSEMBLYAI_SPEAKER_A_NAME=Will
# ASSEMBLYAI_SPEAKER_B_NAME=Aron

# Optional; defaults to gpt-4o-mini
OPENAI_COMPARE_MODEL=gpt-4o-mini
